# Vite asset base: default in vite.config.ts is /portfolio/ (GitHub project Pages).
# For a user site at https://YOURNAME.github.io/ use:
# VITE_BASE_PATH=/

# Optional: override canonical / og:url / JSON-LD when not using siteContent.json meta.siteUrl
# VITE_SITE_URL=https://your-domain.com/portfolio/
